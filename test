<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Chibi Sprite</title>
<style>
body {
  margin: 0;
  background: #ffeef5;
}
canvas {
  display: block;
  margin: auto;
}
</style>
</head>

<body>
<canvas id="game" width="500" height="400"></canvas>

<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

let float = 0;
let direction = 1;

function drawChibi(x, y) {
  
  // head
  ctx.fillStyle = "#ffd1dc";
  ctx.beginPath();
  ctx.arc(x, y, 40, 0, Math.PI * 2);
  ctx.fill();

  // eyes
  ctx.fillStyle = "#333";
  ctx.beginPath();
  ctx.arc(x - 15, y - 5, 4, 0, Math.PI * 2);
  ctx.fill();

  ctx.beginPath();
  ctx.arc(x + 15, y - 5, 4, 0, Math.PI * 2);
  ctx.fill();

  // blush
  ctx.fillStyle = "#ff9aa2";
  ctx.beginPath();
  ctx.arc(x - 25, y + 5, 5, 0, Math.PI * 2);
  ctx.fill();

  ctx.beginPath();
  ctx.arc(x + 25, y + 5, 5, 0, Math.PI * 2);
  ctx.fill();

  // mouth
  ctx.strokeStyle = "#333";
  ctx.beginPath();
  ctx.arc(x, y + 10, 10, 0, Math.PI);
  ctx.stroke();

  // body
  ctx.fillStyle = "#b5ead7";
  ctx.fillRect(x - 20, y + 40, 40, 40);

  // legs
  ctx.fillRect(x - 15, y + 80, 10, 15);
  ctx.fillRect(x + 5, y + 80, 10, 15);
}

function animate() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  float += 0.2 * direction;
  if (float > 5 || float < -5) direction *= -1;

  drawChibi(250, 180 + float);

  requestAnimationFrame(animate);
}

animate();
</script>

</body>
</html>
